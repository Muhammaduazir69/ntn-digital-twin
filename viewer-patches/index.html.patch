+        let twinTimer = null;
+        const liveToggle = document.getElementById('live-toggle');
+        const liveBtn    = document.getElementById('live-btn');
+        const twinUrl    = document.getElementById('twin-url');
+        const twinStatus = document.getElementById('twin-status');
+
+        async function refreshTwin() {
+            const base = twinUrl.value.replace(/\/$/, '');
+            try {
+                const r = await fetch(base + '/constellation/state');
+                if (!r.ok) throw new Error('HTTP ' + r.status);
+                const j = await r.json();
+                // Replace the entity dataset with the live snapshot.
+                viewer.entities.values
+                    .filter(e => e.id && e.id.toString().startsWith('twin-'))
+                    .forEach(e => viewer.entities.remove(e));
+                for (const sat of j.satellites) {
+                    viewer.entities.add({
+                        id: 'twin-' + sat.sat_norad,
+                        name: sat.name,
+                        position: Cesium.Cartesian3.fromDegrees(sat.lon_deg, sat.lat_deg, sat.alt_km * 1000),
+                        point: { pixelSize: 6, color: Cesium.Color.CYAN.withAlpha(0.85) },
+                        label: { text: sat.name, font: '10px sans-serif',
+                                 fillColor: Cesium.Color.WHITE.withAlpha(0.7),
+                                 pixelOffset: new Cesium.Cartesian2(8, 0),
+                                 showBackground: true,
+                                 backgroundColor: Cesium.Color.BLACK.withAlpha(0.5) },
+                    });
+                }
+                twinStatus.textContent =
+                    `${j.count} sats @ ${j.epoch_iso}  (refreshed ${new Date().toLocaleTimeString()})`;
+            } catch (err) {
+                twinStatus.textContent = 'twin error: ' + err.message;
+            }
+        }
+
+        liveBtn.addEventListener('click', () => {
+            if (twinTimer) {
+                clearInterval(twinTimer);
+                twinTimer = null;
+                liveToggle.classList.remove('on');
+                liveBtn.textContent = 'Connect';
+            } else {
+                refreshTwin();
+                twinTimer = setInterval(refreshTwin, 5000);  // 5 s cadence
+                liveToggle.classList.add('on');
+                liveBtn.textContent = 'Disconnect';
+            }
+        });
